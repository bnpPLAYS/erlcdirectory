# Copy to .env and fill in from Supabase → Project Settings → API
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_anon_or_publishable_key
VITE_SUPABASE_PROJECT_ID=YOUR_PROJECT_REF

# Discord OAuth (same application as Supabase Auth “Discord” provider).
# Do NOT put the client secret in git. Add to Supabase → Edge Functions → Secrets:
#   DISCORD_CLIENT_ID
#   DISCORD_CLIENT_SECRET
# Optional in local .env for CLI / notes only; functions read secrets from the dashboard when deployed.
# DISCORD_CLIENT_ID=
# DISCORD_CLIENT_SECRET=
