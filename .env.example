# Copy to .env and fill in from Supabase → Project Settings → API
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_anon_or_publishable_key
VITE_SUPABASE_PROJECT_ID=YOUR_PROJECT_REF

# Discord OAuth (same app as Supabase Auth + Edge Function secrets DISCORD_CLIENT_*)
# Optional: full redirect URL — must match Discord Developer Portal EXACTLY (fixes www vs apex).
# Examples: https://yourdomain.com/discord/callback or https://www.erlc.directory/discord/callback
# VITE_DISCORD_REDIRECT_URI=
# Optional: defaults to a legacy ID in code if unset — should match Edge secrets.
# VITE_DISCORD_CLIENT_ID=
